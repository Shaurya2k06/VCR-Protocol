{
  "name": "server",
  "version": "1.0.0",
  "description": "API server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/workers/storePolicyWorker.ts",
    "dev:register-worker": "tsx watch src/workers/registerAgentWorker.ts",
    "prebuild": "npm install --no-audit --no-fund",
    "build": "tsc -p tsconfig.json",
    "start": "concurrently \"node dist/index.js\" \"node dist/workers/registerAgentWorker.js\"",
    "start:worker": "node dist/workers/storePolicyWorker.js",
    "start:register-worker": "node dist/workers/registerAgentWorker.js",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate-env": "tsx src/validate-env.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@helia/json": "latest",
    "@helia/unixfs": "^5.0.0",
    "@vcr-protocol/sdk": "npm:@soundcodes/vcrsdk-2@1.1.0",
    "bullmq": "^5.61.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helia": "^6.0.0",
    "ioredis": "^5.8.1",
    "mongoose": "^9.3.0",
    "multiformats": "latest",
    "pinata": "latest",
    "viem": "^2.31.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^8.48.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
