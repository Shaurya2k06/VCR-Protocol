{
  "name": "server",
  "version": "1.0.0",
  "description": "API server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prestart": "npm run build",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate-env": "tsx src/validate-env.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@helia/json": "latest",
    "@helia/unixfs": "^5.0.0",
    "@vcr-protocol/sdk": "file:../sdk",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helia": "^6.0.0",
    "mongoose": "^9.3.0",
    "multiformats": "latest",
    "pinata": "latest",
    "viem": "^2.31.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^8.48.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
