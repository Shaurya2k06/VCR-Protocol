# ──────────────────────────────────────────────────
# VCR Protocol — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.
# ──────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/vcr-protocol

# ──────────────────────────────────────────────────
# Wallet (Owner / Signer)
# This key signs ENS records and ERC-8004 registrations
# ──────────────────────────────────────────────────
PRIVATE_KEY=0x...

# ──────────────────────────────────────────────────
# Alchemy (Sepolia RPC)
# ──────────────────────────────────────────────────
ALCHEMY_API_KEY=
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# ──────────────────────────────────────────────────
# ENS
# ──────────────────────────────────────────────────
ENS_NAME=youragent.eth

# ──────────────────────────────────────────────────
# Pinata (IPFS)
# ──────────────────────────────────────────────────
PINATA_JWT=
PINATA_GATEWAY=your-gateway.mypinata.cloud

# ──────────────────────────────────────────────────
# BitGo (Institutional Wallet)
# Test OTP is exactly 7 zeroes: 0000000 (NOT 6!)
# ──────────────────────────────────────────────────
BITGO_ACCESS_TOKEN=v2x...
BITGO_ENTERPRISE_ID=
BITGO_WALLET_ID=
BITGO_WALLET_PASSPHRASE=

# ──────────────────────────────────────────────────
# Pimlico (Account Abstraction for Fileverse)
# ──────────────────────────────────────────────────
PIMLICO_API_KEY=

# ──────────────────────────────────────────────────
# Demo
# ──────────────────────────────────────────────────
DEMO_RECIPIENT_ADDRESS=0x...
