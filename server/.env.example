# Example environment variables for the TypeScript backend.
# Copy to `.env` and replace placeholder values before running.

# Basic
NODE_ENV=development
PORT=4000

# MongoDB (local or Atlas)
# Example local: mongodb://localhost:27017/sneaky-link
# Example Atlas: mongodb+srv://<user>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/sneaky-link

# JWT / Authentication
JWT_SECRET=replace_with_a_strong_jwt_secret
JWT_EXPIRES_IN=7d

# Cookie/session secret (if using cookie-based sessions)
COOKIE_SECRET=replace_with_cookie_secret

# Password hashing
SALT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Optional third-party credentials (uncomment and fill if used)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# SENDGRID_API_KEY=your_sendgrid_api_key
