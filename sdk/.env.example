# ─── VCR Protocol SDK — Environment Configuration ────────────────────────────
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control.
#           The .gitignore already excludes it.
#
# OWNER CREDENTIALS (shared across all agents you create)
# ────────────────────────────────────────────────────────
# These belong to YOU, the operator. One set per deployment.
# Agent-specific data (walletId, agentId, policyCid) goes in agents/<name>.json
# after creation — NOT here.

# ── BitGo ─────────────────────────────────────────────────────────────────────

# Your BitGo API access token (v2x...)

BITGO_ACCESS_TOKEN=v2x87a9d48d82073e17f38985fe695b5e031fa204735156c2f58693b53d769cda21
# Your BitGo enterprise ID (found in BitGo dashboard → Enterprise Settings)

BITGO_ENTERPRISE_ID=69b444578ffb2bac3e9baf614e46ce05
# ── Pinata (IPFS) ─────────────────────────────────────────────────────────────

# Pinata JWT from https://app.pinata.cloud/developers/api-keys
# Must have pinning + gateway read permissions

PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..YecSREX2qjYZW5Y5uxOIC5XFEJhNbkcHKhV3zK4r3B4

# Your dedicated Pinata gateway subdomain (WITHOUT https://)
# e.g. amber-sophisticated-bovid-196.mypinata.cloud

PINATA_GATEWAY=rose-obliged-wildcat-829.mypinata.cloud
# ── Ethereum / ENS ────────────────────────────────────────────────────────────

# Private key of the EOA that OWNS all the ENS names you'll register agents on.
# Must be prefixed with 0x.
# ⚠️  Keep this secret. This key signs ENS text record transactions.

PRIVATE_KEY=d24d778c8156e904374d70f4bc4ff28543a343af4c57d03e6d383f487e5d3eda
# Sepolia RPC URL — used for ENS reads/writes and ERC-8004 registration.
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/<YOUR_KEY>
# Infura:  https://sepolia.infura.io/v3/<YOUR_KEY>
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# ── Optional ──────────────────────────────────────────────────────────────────

# Mainnet RPC (only needed if deploying to mainnet)
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE

# Alchemy API key (used for enhanced APIs, optional)

ALCHEMY_API_KEY=csUE-7olp8SPn4-bw2S35
# Pimlico API key (used for account abstraction / paymasters, optional)

PIMLICO_API_KEY=pim_gVXDc7uaTaa7LfZ1mdeqcp
# On-chain VCRPolicyRegistry contract address (optional — only needed if you
# deployed the registry contract yourself)
VCR_REGISTRY_ADDRESS=0xA3FDeFAbe5C40a371138d6FFcBf203f35C4d69BC

# ── setup-agent.ts CLI defaults (optional) ────────────────────────────────────
# These are used as fallbacks when CLI flags are not provided to `npm run setup`.

# Default agent name (used in ENS: <AGENT_NAME>.<ENS_BASE_DOMAIN>)
# AGENT_NAME=researcher-001

# Default ENS base domain (must be owned by PRIVATE_KEY)
# ENS_BASE_DOMAIN=acmecorp.eth

# Default max per-transaction limit in USDC (human-readable, e.g. "500" = $500)
# MAX_TX_USDC=500

# Default daily cumulative limit in USDC (human-readable, e.g. "5000" = $5,000)
# DAILY_LIMIT_USDC=5000

# Comma-separated list of whitelisted recipient addresses
# ⚠️  FINAL — BitGo policy rules lock after 48 hours and cannot be changed.
#     Add every address the agent will ever need to pay.
# ALLOWED_RECIPIENTS=0xABC...,0xDEF...

# Comma-separated allowed token symbols
# ALLOWED_TOKENS=USDC

# Comma-separated allowed chain identifiers
# ALLOWED_CHAINS=base-sepolia

# Optional agent description
# AGENT_DESCRIPTION=Research budget agent for team-001

# ─────────────────────────────────────────────────────────────────────────────
# DO NOT PUT THESE HERE — they are per-agent, written to agents/<name>.json
# ─────────────────────────────────────────────────────────────────────────────
# BITGO_WALLET_ID          ← output of createAgent()
# BITGO_WALLET_PASSPHRASE  ← stored in agents/<name>.json (never in .env)
# ENS_NAME                 ← generated per agent: <name>.<baseDomain>
# AGENT_ID                 ← output of ERC-8004 registration
# POLICY_CID               ← output of IPFS pin
